{
  "name": "portfolio-api-automation-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo QA Automation portfolio with a CRUD API and three automation frameworks.",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.16.0"
  },
  "scripts": {
    "api:start": "pnpm --filter @portfolio/api start",
    "api:dev": "pnpm --filter @portfolio/api dev",
    "audit": "pnpm audit --audit-level moderate",
    "test:playwright": "pnpm --filter @portfolio/playwright-api test",
    "allure:generate": "pnpm exec allure generate tests/rest-assured-java/target/allure-results tests/playwright-ts/allure-results --clean -o allure-report",
    "allure:open": "pnpm exec allure open allure-report"
  },
  "keywords": [
    "qa",
    "automation",
    "api",
    "crud",
    "playwright",
    "rest-assured",
    "pytest",
    "pnpm",
    "github-actions"
  ],
  "license": "MIT",
  "devDependencies": {
    "allure": "3.9.0"
  }
}